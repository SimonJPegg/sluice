{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["image", "service", "rateLimiting", "policies", "redis", "auth"],
  "properties": {
    "auth": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable API key authentication on the /check endpoint"
        },
        "existingSecret": {
          "type": "string",
          "description": "Name of an existing Kubernetes Secret containing the API key (must have a key named 'api-key')"
        }
      },
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["existingSecret"],
        "properties": {
          "existingSecret": {
            "minLength": 1
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of sluice replicas"
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Container image repository"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "description": "Image pull policy"
        },
        "tag": {
          "type": "string",
          "description": "Image tag override"
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "description": "Service type"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Service port"
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ingress"
        },
        "ingressClassName": {
          "type": "string",
          "description": "Ingress class name"
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "description": "Hostname for the ingress"
        },
        "annotations": {
          "type": "object",
          "description": "Ingress annotations",
          "additionalProperties": { "type": "string" }
        },
        "tls": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "secretName": {
                  "type": "string",
                  "description": "TLS secret name"
                }
              }
            },
            {
              "type": "boolean",
              "const": false
            }
          ],
          "description": "TLS configuration (set to false to disable)"
        }
      },
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["host"]
      }
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context"
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context"
    },
    "resources": {
      "type": "object",
      "description": "Pod resource requests and limits"
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration"
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration"
    },
    "rateLimiting": {
      "type": "object",
      "required": ["maxIdentifierLength", "circuitBreaker"],
      "properties": {
        "maxIdentifierLength": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum length of the rate limit key identifier"
        },
        "maxConcurrentRequests": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum concurrent requests before load shedding (omit to disable)"
        },
        "circuitBreaker": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable circuit breaker on the counter store"
            },
            "errorThreshold": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of consecutive failures before the circuit opens"
            },
            "timeoutMs": {
              "type": "integer",
              "minimum": 1,
              "description": "Time in milliseconds before a half-open probe is attempted"
            }
          },
          "if": {
            "properties": { "enabled": { "const": true } }
          },
          "then": {
            "required": ["errorThreshold", "timeoutMs"]
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "minProperties": 1,
      "description": "Policy files to mount (at least one required)",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "redis": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable bundled Redis deployment"
        },
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Redis container image"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Redis port"
        },
        "podSecurityContext": {
          "type": "object",
          "description": "Pod-level security context for Redis"
        },
        "securityContext": {
          "type": "object",
          "description": "Container-level security context for Redis"
        },
        "resources": {
          "type": "object",
          "description": "Redis resource requests and limits"
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Prometheus ServiceMonitor"
        },
        "interval": {
          "type": "string",
          "pattern": "^[0-9]+(s|m)$",
          "description": "Scrape interval"
        },
        "labels": {
          "type": "object",
          "description": "Additional labels for ServiceMonitor discovery"
        }
      }
    }
  }
}
